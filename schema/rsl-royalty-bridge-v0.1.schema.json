{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schema/rsl-royalty-bridge-v0.1.schema.json",
  "title": "RSL to Kazene Royalty OS Bridge Specification Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "spec"
  ],
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "nullableString": {
      "type": [
        "string",
        "null"
      ]
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stringMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "descriptor": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/descriptor"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/descriptor"
          }
        }
      ]
    },
    "pipelineStep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step",
        "input",
        "output",
        "rules"
      ],
      "properties": {
        "step": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "input": {
          "$ref": "#/$defs/stringArray"
        },
        "output": {
          "$ref": "#/$defs/stringArray"
        },
        "rules": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "bridgeObject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "description": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "requiredAndShapeBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "shape"
      ],
      "properties": {
        "required": {
          "$ref": "#/$defs/stringArray"
        },
        "shape": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/descriptor"
          }
        }
      }
    }
  },
  "properties": {
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "status",
        "language",
        "version",
        "last_updated",
        "purpose",
        "non_goals",
        "compatibility",
        "source_model",
        "target_model",
        "bridge_objects",
        "pipeline",
        "mapping",
        "access_snapshot_schema",
        "trace_event_schema",
        "external_charge_event_schema",
        "royalty_settlement_schema",
        "calculation_rules",
        "join_rules",
        "error_policy",
        "audit_requirements",
        "example"
      ],
      "properties": {
        "id": {
          "const": "rsl-royalty-bridge-v0.1"
        },
        "title": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "status": {
          "type": "string",
          "enum": [
            "proposed",
            "draft",
            "stable"
          ]
        },
        "language": {
          "type": "string",
          "enum": [
            "ja",
            "en"
          ]
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "last_updated": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "purpose": {
          "$ref": "#/$defs/stringArray"
        },
        "non_goals": {
          "$ref": "#/$defs/stringArray"
        },
        "compatibility": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "source_standard",
            "target_standard",
            "preservation_principles"
          ],
          "properties": {
            "source_standard": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "target_standard": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "preservation_principles": {
              "$ref": "#/$defs/stringArray"
            }
          }
        },
        "source_model": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "rsl"
          ],
          "properties": {
            "rsl": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "namespace",
                "media_type",
                "root_element",
                "primary_elements",
                "discovery_channels",
                "canonical_identity"
              ],
              "properties": {
                "namespace": {
                  "$ref": "#/$defs/nonEmptyString"
                },
                "media_type": {
                  "$ref": "#/$defs/nonEmptyString"
                },
                "root_element": {
                  "$ref": "#/$defs/nonEmptyString"
                },
                "primary_elements": {
                  "$ref": "#/$defs/stringArray"
                },
                "discovery_channels": {
                  "$ref": "#/$defs/stringArray"
                },
                "canonical_identity": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "content_url_is_canonical_license_id",
                    "content_server_plus_url_is_authoritative_when_present"
                  ],
                  "properties": {
                    "content_url_is_canonical_license_id": {
                      "type": "boolean"
                    },
                    "content_server_plus_url_is_authoritative_when_present": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          }
        },
        "target_model": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "royalty_os"
          ],
          "properties": {
            "royalty_os": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "layers",
                "internal_unit"
              ],
              "properties": {
                "layers": {
                  "$ref": "#/$defs/stringArray"
                },
                "internal_unit": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "name",
                    "convertible",
                    "transferable",
                    "external_wallet"
                  ],
                  "properties": {
                    "name": {
                      "$ref": "#/$defs/nonEmptyString"
                    },
                    "convertible": {
                      "type": "boolean"
                    },
                    "transferable": {
                      "type": "boolean"
                    },
                    "external_wallet": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          }
        },
        "bridge_objects": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/bridgeObject"
          }
        },
        "pipeline": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/pipelineStep"
          }
        },
        "mapping": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "content",
            "license",
            "permits_and_prohibits",
            "royalty_os_access_projection",
            "payment",
            "legal"
          ],
          "properties": {
            "content": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "source",
                "target"
              ],
              "properties": {
                "source": {
                  "$ref": "#/$defs/stringArray"
                },
                "target": {
                  "$ref": "#/$defs/stringMap"
                }
              }
            },
            "license": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "source",
                "target"
              ],
              "properties": {
                "source": {
                  "$ref": "#/$defs/stringArray"
                },
                "target": {
                  "$ref": "#/$defs/stringMap"
                }
              }
            },
            "permits_and_prohibits": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "precedence",
                "token_sets"
              ],
              "properties": {
                "precedence": {
                  "$ref": "#/$defs/nonEmptyString"
                },
                "token_sets": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "usage",
                    "user"
                  ],
                  "properties": {
                    "usage": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": [
                        "all",
                        "ai-all",
                        "ai-train",
                        "ai-input",
                        "ai-index",
                        "search"
                      ],
                      "properties": {
                        "all": {
                          "$ref": "#/$defs/descriptor"
                        },
                        "ai-all": {
                          "$ref": "#/$defs/descriptor"
                        },
                        "ai-train": {
                          "$ref": "#/$defs/descriptor"
                        },
                        "ai-input": {
                          "$ref": "#/$defs/descriptor"
                        },
                        "ai-index": {
                          "$ref": "#/$defs/descriptor"
                        },
                        "search": {
                          "$ref": "#/$defs/descriptor"
                        }
                      }
                    },
                    "user": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": [
                        "commercial",
                        "non-commercial",
                        "education",
                        "government",
                        "personal"
                      ],
                      "properties": {
                        "commercial": {
                          "$ref": "#/$defs/descriptor"
                        },
                        "non-commercial": {
                          "$ref": "#/$defs/descriptor"
                        },
                        "education": {
                          "$ref": "#/$defs/descriptor"
                        },
                        "government": {
                          "$ref": "#/$defs/descriptor"
                        },
                        "personal": {
                          "$ref": "#/$defs/descriptor"
                        }
                      }
                    }
                  }
                }
              }
            },
            "royalty_os_access_projection": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "rules",
                "fields"
              ],
              "properties": {
                "rules": {
                  "$ref": "#/$defs/stringArray"
                },
                "fields": {
                  "$ref": "#/$defs/stringMap"
                }
              }
            },
            "payment": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "default_when_omitted",
                "mapping",
                "child_elements"
              ],
              "properties": {
                "default_when_omitted": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "payment_type",
                    "billing_required"
                  ],
                  "properties": {
                    "payment_type": {
                      "$ref": "#/$defs/nonEmptyString"
                    },
                    "billing_required": {
                      "type": "boolean"
                    }
                  }
                },
                "mapping": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "purchase",
                    "subscription",
                    "training",
                    "crawl",
                    "use",
                    "contribution",
                    "attribution",
                    "free"
                  ],
                  "properties": {
                    "purchase": {
                      "$ref": "#/$defs/descriptor"
                    },
                    "subscription": {
                      "$ref": "#/$defs/descriptor"
                    },
                    "training": {
                      "$ref": "#/$defs/descriptor"
                    },
                    "crawl": {
                      "$ref": "#/$defs/descriptor"
                    },
                    "use": {
                      "$ref": "#/$defs/descriptor"
                    },
                    "contribution": {
                      "$ref": "#/$defs/descriptor"
                    },
                    "attribution": {
                      "$ref": "#/$defs/descriptor"
                    },
                    "free": {
                      "$ref": "#/$defs/descriptor"
                    }
                  }
                },
                "child_elements": {
                  "$ref": "#/$defs/stringMap"
                }
              }
            },
            "legal": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "preserve_all",
                "target"
              ],
              "properties": {
                "preserve_all": {
                  "type": "boolean"
                },
                "target": {
                  "$ref": "#/$defs/descriptor"
                }
              }
            }
          }
        },
        "access_snapshot_schema": {
          "$ref": "#/$defs/requiredAndShapeBlock"
        },
        "trace_event_schema": {
          "$ref": "#/$defs/requiredAndShapeBlock"
        },
        "external_charge_event_schema": {
          "$ref": "#/$defs/requiredAndShapeBlock"
        },
        "royalty_settlement_schema": {
          "$ref": "#/$defs/requiredAndShapeBlock"
        },
        "calculation_rules": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "q_formula",
            "monetary_formula"
          ],
          "properties": {
            "q_formula": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "expression",
                "defaults"
              ],
              "properties": {
                "expression": {
                  "$ref": "#/$defs/nonEmptyString"
                },
                "defaults": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "base_unit",
                    "action_coef",
                    "work_coef",
                    "scope_coef"
                  ],
                  "properties": {
                    "base_unit": {
                      "type": "number"
                    },
                    "action_coef": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": [
                        "view",
                        "summarize",
                        "quote",
                        "external_response",
                        "grounding",
                        "ai_index",
                        "search_index",
                        "train",
                        "other"
                      ],
                      "properties": {
                        "view": {
                          "type": "number"
                        },
                        "summarize": {
                          "type": "number"
                        },
                        "quote": {
                          "type": "number"
                        },
                        "external_response": {
                          "type": "number"
                        },
                        "grounding": {
                          "type": "number"
                        },
                        "ai_index": {
                          "type": "number"
                        },
                        "search_index": {
                          "type": "number"
                        },
                        "train": {
                          "type": "number"
                        },
                        "other": {
                          "type": "number"
                        }
                      }
                    },
                    "work_coef": {
                      "type": "number"
                    },
                    "scope_coef": {
                      "type": "number"
                    }
                  }
                }
              }
            },
            "monetary_formula": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "when_external_fee_exists",
                "when_external_fee_absent",
                "allocable_amount_rule"
              ],
              "properties": {
                "when_external_fee_exists": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "expression"
                  ],
                  "properties": {
                    "expression": {
                      "$ref": "#/$defs/nonEmptyString"
                    }
                  }
                },
                "when_external_fee_absent": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "expression"
                  ],
                  "properties": {
                    "expression": {
                      "$ref": "#/$defs/nonEmptyString"
                    }
                  }
                },
                "allocable_amount_rule": {
                  "$ref": "#/$defs/nonEmptyString"
                }
              }
            }
          }
        },
        "join_rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "rule"
            ],
            "properties": {
              "name": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "rule": {
                "$ref": "#/$defs/nonEmptyString"
              }
            }
          }
        },
        "error_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "parser_errors",
            "transformation_errors",
            "handling"
          ],
          "properties": {
            "parser_errors": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "code"
                ],
                "properties": {
                  "code": {
                    "$ref": "#/$defs/nonEmptyString"
                  }
                }
              }
            },
            "transformation_errors": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "code"
                ],
                "properties": {
                  "code": {
                    "$ref": "#/$defs/nonEmptyString"
                  }
                }
              }
            },
            "handling": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "invalid_source",
                "unknown_extension",
                "unmapped_standard_token"
              ],
              "properties": {
                "invalid_source": {
                  "$ref": "#/$defs/nonEmptyString"
                },
                "unknown_extension": {
                  "$ref": "#/$defs/nonEmptyString"
                },
                "unmapped_standard_token": {
                  "$ref": "#/$defs/nonEmptyString"
                }
              }
            }
          }
        },
        "audit_requirements": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "must_log",
            "retention"
          ],
          "properties": {
            "must_log": {
              "$ref": "#/$defs/stringArray"
            },
            "retention": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "access_snapshot",
                "trace_event",
                "settlement"
              ],
              "properties": {
                "access_snapshot": {
                  "$ref": "#/$defs/nonEmptyString"
                },
                "trace_event": {
                  "$ref": "#/$defs/nonEmptyString"
                },
                "settlement": {
                  "$ref": "#/$defs/nonEmptyString"
                }
              }
            }
          }
        },
        "example": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "input_rsl_xml",
            "output_access_snapshot_yaml",
            "output_trace_event_yaml",
            "output_external_charge_event_yaml",
            "output_royalty_settlement_yaml"
          ],
          "properties": {
            "input_rsl_xml": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "output_access_snapshot_yaml": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "output_trace_event_yaml": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "output_external_charge_event_yaml": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "output_royalty_settlement_yaml": {
              "$ref": "#/$defs/nonEmptyString"
            }
          }
        }
      }
    }
  }
}
